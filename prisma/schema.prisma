// Nexora Shipping - Prisma Schema
// Database: Google Cloud SQL (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
  DRIVER
}

enum ShipmentStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  CANCELLED
  RETURNED
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum AccountGroupType {
  ASSET
  LIABILITIES
  PL
  TRADING
}

enum VoucherType {
  CASH
  PURCHASE
  PAYMENT
  BANK
  JOURNAL
  RECEIPT
  SUPPLIER_PAYMENT
  CREDIT_NOTE
  DEBIT_NOTE
}

enum VoucherDirection {
  DEBIT
  CREDIT
}

enum VoucherReferenceType {
  NONE
  INVOICE
  ORDER
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  firstName    String
  lastName     String
  phone        String?
  role         Role     @default(CUSTOMER)
  isVerified   Boolean  @default(false)
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders     Order[]
  shipments  Shipment[]
  documents  Document[]
  invoices   Invoice[]
  quotations Quotation[]
  vouchers   Voucher[]

  @@map("users")
}

model Order {
  id                  String      @id @default(uuid())
  orderNumber         String      @unique
  status              OrderStatus @default(DRAFT)
  pickupAddress       String
  pickupCity          String
  pickupCountry       String
  deliveryAddress     String
  deliveryCity        String
  deliveryCountry     String
  packageDescription  String
  weight              Float
  length              Float?
  width               Float?
  height              Float?
  cbm                 Float?
  declaredValue       Float?
  price               Float?
  specialInstructions String?
  userId              String
  repId               String?
  repName             String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  salesperson Salesperson? @relation("OrderSalesperson", fields: [repId], references: [id])
  shipment    Shipment?
  documents   Document[]
  invoices    Invoice[]
  quotations  Quotation[]
  vouchers    Voucher[]

  @@map("orders")
}

model Shipment {
  id               String         @id @default(uuid())
  trackingNumber   String         @unique
  status           ShipmentStatus @default(PENDING)
  origin           String
  destination      String
  currentLocation  String?
  weight           Float
  description      String?
  carrier          String?
  estimatedDelivery DateTime?
  actualDelivery   DateTime?
  userId           String
  orderId          String?        @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user      User             @relation(fields: [userId], references: [id])
  order     Order?           @relation(fields: [orderId], references: [id])
  events    ShipmentEvent[]
  documents Document[]

  @@map("shipments")
}

model ShipmentEvent {
  id          String         @id @default(uuid())
  shipmentId  String
  status      ShipmentStatus
  location    String
  description String
  timestamp   DateTime       @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("shipment_events")
}

model Document {
  id           String   @id @default(uuid())
  name         String
  originalName String
  mimeType     String
  size         Int
  url          String
  gcsPath      String
  type         String   // invoice, bill_of_lading, customs, proof_of_delivery, other
  orderId      String?
  shipmentId   String?
  uploadedBy   String
  createdAt    DateTime @default(now())

  order    Order?    @relation(fields: [orderId], references: [id])
  shipment Shipment? @relation(fields: [shipmentId], references: [id])
  user     User      @relation(fields: [uploadedBy], references: [id])

  @@map("documents")
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  status        InvoiceStatus @default(DRAFT)
  invoiceDate   DateTime      @default(now())
  dueDate       DateTime?

  // Bill To
  billToName    String
  billToAddress String
  billToCity    String
  billToCountry String
  billToEmail   String?
  billToPhone   String?

  // Ship From (company)
  shipFromName    String @default("Nexora Express")
  shipFromAddress String @default("1 Nexora Way")
  shipFromCity    String @default("London")
  shipFromCountry String @default("GB")

  // Issuer / company
  companyTrn   String?

  // Shipment header
  jobNo          String?
  originPort     String?
  destPort       String?
  masterBl       String?
  houseBl        String?
  commodity      String?
  boeNumber      String?
  grossWeight    String?
  volume         String?
  packages       String?
  shipperName    String?
  consigneeName  String?
  customerRef    String?

  // Financial
  currency     String @default("AED")
  subtotal     Float  @default(0)
  taxRate      Float  @default(0)
  taxAmount    Float  @default(0)
  shippingCost Float  @default(0)
  total        Float  @default(0)
  amountInWords String?

  // Bank details
  bankName      String?
  bankAddress   String?
  accountName   String?
  accountNumber String?
  iban          String?
  swiftCode     String?

  // Meta
  paymentTerms String?
  notes        String?

  // Relations
  orderId   String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id])
  orderRef Order?        @relation(fields: [orderId], references: [id])
  items    InvoiceItem[]
  vouchers Voucher[]

  @@map("invoices")
}

model InvoiceItem {
  id             String  @id @default(uuid())
  invoiceId      String
  description    String
  quantity       Float   @default(1)
  unitPrice      Float
  amount         Float
  lineCurrency   String?
  exchangeRate   Float?  @default(1)
  vatPercent     Float?  @default(0)
  vatAmount      Float?  @default(0)
  totalInBase    Float?
  remarks        String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Quotation {
  id              String          @id @default(uuid())
  quotationNumber String          @unique
  status          QuotationStatus @default(DRAFT)
  quotationDate   DateTime        @default(now())
  validUntil      DateTime?

  // Bill To / Client
  billToName    String
  billToAddress String
  billToCity    String
  billToCountry String
  billToEmail   String?
  billToPhone   String?

  // Ship From (company)
  shipFromName    String @default("Nexora Express")
  shipFromAddress String @default("1 Nexora Way")
  shipFromCity    String @default("London")
  shipFromCountry String @default("GB")

  // Financial
  currency     String @default("USD")
  subtotal     Float  @default(0)
  taxRate      Float  @default(0)
  taxAmount    Float  @default(0)
  shippingCost Float  @default(0)
  total        Float  @default(0)

  // Meta
  terms String?
  notes String?

  // Relations
  orderId   String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id])
  orderRef Order?           @relation(fields: [orderId], references: [id])
  items    QuotationItem[]

  @@map("quotations")
}

model QuotationItem {
  id          String  @id @default(uuid())
  quotationId String
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  amount      Float

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@map("quotation_items")
}

model AccountGroup {
  id         String           @id @default(uuid())
  code       String           @unique
  name       String
  groupType  AccountGroupType
  printOrder Int              @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  accounts Account[]

  @@map("account_groups")
}

model CustomerGroup {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]

  @@map("customer_groups")
}

model Salesperson {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  phone     String?
  email     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  primaryAccounts   Account[] @relation("AccountPrimarySalesperson")
  secondaryAccounts Account[] @relation("AccountSecondarySalesperson")
  orders            Order[]   @relation("OrderSalesperson")

  @@map("salespersons")
}

model Account {
  id              String  @id @default(uuid())
  code            String  @unique
  name            String
  arabicName      String?
  accountGroupId  String
  destination     String?
  address         String?
  road            String?
  place           String?
  route           String?
  subRoute        String?
  phone1          String?
  mobile1         String?
  mobile2         String?
  email           String?
  financeEmail    String?
  contactPerson   String?
  acContactPerson String?
  acMobileNo      String?
  rep             String?
  rep2            String?
  repId           String?
  rep2Id          String?
  opBalance       Float   @default(0)
  opBalanceType   String  @default("Credit")
  narration       String?
  paymentTerms    String?
  trn             String?
  creditDays      Int     @default(0)
  creditInvoices  Int     @default(0)
  creditLimit     Float   @default(0)
  customerGroupId String?
  deliveryAddress String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accountGroup       AccountGroup   @relation(fields: [accountGroupId], references: [id])
  customerGroup      CustomerGroup? @relation(fields: [customerGroupId], references: [id])
  salesperson        Salesperson?   @relation("AccountPrimarySalesperson", fields: [repId], references: [id])
  salesperson2       Salesperson?   @relation("AccountSecondarySalesperson", fields: [rep2Id], references: [id])
  subAccounts        SubAccount[]

  @@map("accounts")
}

model SubAccount {
  id        String   @id @default(uuid())
  code      String
  name      String
  accountId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, code])
  @@map("sub_accounts")
}

model ItemMaster {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("item_masters")
}

model ChargeItem {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  defaultRate Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("charge_items")
}

model BankAccount {
  id            String   @id @default(uuid())
  label         String   @unique
  bankName      String
  bankAddress   String?
  accountName   String
  accountNumber String
  iban          String?
  swiftCode     String?
  currency      String?
  companyTrn    String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("bank_accounts")
}

model Voucher {
  id            String               @id @default(uuid())
  voucherNumber String               @unique
  type          VoucherType
  direction     VoucherDirection
  voucherDate   DateTime             @default(now())
  amount        Float
  currency      String               @default("AED")
  referenceType VoucherReferenceType @default(NONE)
  invoiceId     String?
  orderId       String?
  partyName     String?
  narration     String?
  fileUrl       String?
  fileName      String?
  fileMimeType  String?
  fileSize      Int?
  gcsPath       String?
  userId        String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])
  order   Order?   @relation(fields: [orderId], references: [id])

  @@index([invoiceId])
  @@index([orderId])
  @@map("vouchers")
}
