# =====================================================
# NEXORA SHIPPING BACKEND - Environment Variables
# Copy this file to .env and fill in your values
# =====================================================

# App
NODE_ENV=development
PORT=8080

# Database - Google Cloud SQL (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# For Cloud SQL via Cloud SQL Proxy: postgresql://USER:PASSWORD@localhost:5432/DATABASE
# For Cloud SQL direct (production): postgresql://USER:PASSWORD@CLOUD_SQL_IP:5432/DATABASE?sslmode=require
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/nexora_shipping"

# JWT Secrets (generate with: openssl rand -base64 64)
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-this"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Google Cloud Platform
GOOGLE_CLOUD_PROJECT_ID="your-gcp-project-id"
GCS_BUCKET_NAME="nexora-shipping-docs"

# Option 1: Path to service account key file (local dev)
GOOGLE_APPLICATION_CREDENTIALS="./service-account-key.json"

# Option 2: Service account JSON as string (Render deployment)
# GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'
